# ── Twilio ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox number

# ── Groq (AI fallback) ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Turf Config ────────────────────────────────────────────────────────────────
TURF_NAME=Champions Turf
TURF_LOCATION=Anna Nagar, Chennai
TURF_OPEN_HOUR=6
TURF_CLOSE_HOUR=23
TURF_PRICE_PER_SLOT=600
ADVANCE_AMOUNT=300
UPI_ID=yourname@upi

# ── Owner WhatsApp numbers (E.164, comma-separated, no spaces) ─────────────────
OWNER_NUMBERS=whatsapp:+919876543210,whatsapp:+919123456789

# ── Database path ─────────────────────────────────────────────────────────────
# Set to /data/turf.db on Render (persistent disk)
DB_PATH=turf.db

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Set to True in production. Set to False in local dev (no signature header from Twilio).
VALIDATE_TWILIO_SIGNATURE=False

# EMERGENCY ONLY — bypass signature validation. Logs a CRITICAL warning if True.
# Must NEVER be True in normal production operation.
ALLOW_SIGNATURE_BYPASS=False
